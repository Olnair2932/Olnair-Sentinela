<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Sentinela IA Pro - Olnair</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>
<body class="bg-slate-950 text-white font-sans">

    <!-- TELA DE LOGIN -->
    <div id="auth-screen" class="h-screen flex flex-col items-center justify-center p-6 text-center">
        <div class="mb-6 p-4 bg-blue-600 rounded-full shadow-[0_0_20px_rgba(37,99,235,0.5)]">
            <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
        </div>
        <h1 class="text-2xl font-bold text-blue-400 mb-2">SENTINELA</h1>
        <p class="text-slate-500 text-sm mb-8 uppercase tracking-tighter">Acesso exclusivo do desenvolvedor Olnair</p>
        <button id="login-btn" class="bg-white text-black px-8 py-3 rounded-xl font-bold hover:bg-slate-200 transition-all flex items-center gap-2">
            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/action/google.svg" class="w-5" alt="G">
            Entrar com Google
        </button>
    </div>

    <!-- INTERFACE DO CHAT -->
    <div id="app" class="hidden max-w-2xl mx-auto h-screen flex flex-col p-4">
        <header class="py-4 border-b border-slate-800 flex justify-between items-center">
            <div>
                <h1 class="text-xl font-bold text-blue-400">SENTINELA</h1>
                <p class="text-[10px] text-slate-500 uppercase tracking-widest">Memória Unificada</p>
            </div>
            <div class="flex items-center gap-2">
                <!-- BOTÃO DE DOWNLOAD VERDE -->
                <button id="download-btn" class="text-[10px] bg-green-600 hover:bg-green-500 text-white px-3 py-1 rounded font-bold transition shadow-lg shadow-green-900/20">BAIXAR TXT</button>
                <button id="limpar-btn" onclick="limparConversa()" class="text-[10px] bg-yellow-900/30 hover:bg-yellow-700 text-yellow-400 px-3 py-1 rounded border border-yellow-900 transition">LIMPAR</button> <button id="reset-btn" onclick="resetarSentinela()" class="text-[10px] bg-red-900/30 hover:bg-red-700 text-red-400 px-3 py-1 rounded border border-red-900 transition">RESET</button> <button id="logout-btn" class="text-[10px] bg-slate-800 hover:bg-red-900/30 text-slate-400 px-3 py-1 rounded border border-slate-700 transition">SAIR</button>
            </div>
        </header>

        <div id="chat" class="flex-1 overflow-y-auto my-4 space-y-4 p-2 text-sm custom-scrollbar">
            <p class="text-slate-500 italic text-center">Sincronizado com Firestore global...</p>
        </div>

        <div id="loading" class="hidden text-xs text-blue-400 animate-pulse mb-2 ml-2">Sentinela processando...</div>

        <div class="pb-6">
            <div class="flex gap-2 bg-slate-900 p-2 rounded-xl border border-slate-800 focus-within:border-blue-500 transition">
                <input id="msg" class="flex-1 bg-transparent border-none p-2 text-white focus:outline-none" placeholder="Digite sua mensagem..." onkeypress="if(event.key==='Enter') enviar()">
                <button onclick="enviar()" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg font-bold transition">ENVIAR</button>
            </div>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getAuth, signInWithPopup, GoogleAuthProvider, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
        import { getDatabase, ref, push, onChildAdded, limitToLast, query } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js";
import { set } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js";

        const firebaseConfig = {
            apiKey: "AIzaSyChFSykoyH7dx4luUtEw_0ouxAZC7AfZOQ",
            authDomain: "minhaiamemoria.firebaseapp.com",
            databaseURL: "https://minhaiamemoria-default-rtdb.firebaseio.com",
            projectId: "minhaiamemoria",
            storageBucket: "minhaiamemoria.firebasestorage.app",
            messagingSenderId: "769423273908",
            appId: "1:769423273908:web:77228eab569b85d29e8ce1"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const rtdb = getDatabase(app);
        const provider = new GoogleAuthProvider();
        
        const authScreen = document.getElementById('auth-screen');
        const appScreen = document.getElementById('app');
        const chatDiv = document.getElementById('chat');
        const loading = document.getElementById('loading');

        document.getElementById('login-btn').onclick = () => signInWithPopup(auth, provider);
        document.getElementById('logout-btn').onclick = () => signOut(auth).then(() => location.reload());

        // LÓGICA DO BOTÃO DE DOWNLOAD
        document.getElementById('download-btn').onclick = () => {
            let textoParaDownload = "RELATÓRIO DE CONVERSA - SENTINELA IA\n";
            textoParaDownload += "Data: " + new Date().toLocaleString() + "\n";
            textoParaDownload += "-------------------------------------------\n\n";
            
            const mensagens = chatDiv.querySelectorAll('div');
            mensagens.forEach(m => {
                const remetente = m.classList.contains('text-right') ? "VOCÊ" : "SENTINELA";
                textoParaDownload += `[${remetente}]: ${m.innerText}\n\n`;
            });

            const blob = new Blob([textoParaDownload], { type: 'text/plain' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = "conversa_sentinela.txt";
            link.click();
        };

        onAuthStateChanged(auth, (user) => {
            if (user && user.email === "olnairpereira@gmail.com") {
                authScreen.classList.add('hidden');
                appScreen.classList.remove('hidden');
                iniciarEscuta();
            } else if (user) {
                alert("Acesso negado.");
                signOut(auth);
            }
        });

window.limparConversa = () => {
    if(confirm("Deseja apagar todo o histórico de conversas?")) {
        set(ref(rtdb, "controle/limpar"), true);
    }
};

window.resetarSentinela = () => {
    if(confirm("Confirmar reinicio do Sentinela?")) {
        set(ref(rtdb, "controle/reset"), true);
    }
};

        function iniciarEscuta() {
            window.enviar = () => {
                const val = document.getElementById('msg').value;
                if(!val) return;
                loading.classList.remove('hidden');
                push(ref(rtdb, 'fila_entrada'), { texto: val, origem: 'web', data: Date.now() });
                chatDiv.innerHTML += `<div class="bg-slate-800/50 p-3 rounded-lg ml-12 text-right border border-slate-700 text-slate-200">${val}</div>`;
                document.getElementById('msg').value = '';
                chatDiv.scrollTop = chatDiv.scrollHeight;
            };

            const respostasRef = ref(rtdb, 'respostas');
            onChildAdded(respostasRef, (snapshot) => {
                loading.classList.add('hidden');
                const res = snapshot.val().texto;
                chatDiv.innerHTML += `<div class="bg-blue-900/10 p-4 rounded-lg mr-12 border border-blue-800/50 text-slate-100 markdown-body">
                    <b class="text-blue-400 block mb-1">SENTINELA:</b> ${marked.parse(res)}
                </div>`;
                chatDiv.scrollTop = chatDiv.scrollHeight;
            });
        }
    </script>

    <style>
        .markdown-body table { border-collapse: collapse; width: 100%; margin: 10px 0; font-size: 12px; border: 1px solid #334155; }
        .markdown-body th, .markdown-body td { border: 1px solid #334155; padding: 8px; text-align: left; }
        .markdown-body th { background-color: #1e293b; color: #60a5fa; }
        .markdown-body ul { list-style: disc; padding-left: 20px; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
    </style>
</body>
</html>
